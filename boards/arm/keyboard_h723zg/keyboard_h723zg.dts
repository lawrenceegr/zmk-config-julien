/dts-v1/;
#include <st/h7/stm32h723Xg.dtsi>
#include <st/h7/stm32h723zgtx-pinctrl.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/led/led.h>
#include "keyboard_h723zg-layouts.dtsi"

/ {
	model = "Custom STM32H723ZG-based Keyboard";
	compatible = "generic,keyboard_h723zg";

	chosen {
		zephyr,console = &usart2;
		zephyr,shell-uart = &usart2;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,dtcm = &dtcm;
		zephyr,settings-partition = &storage_partition;
		zmk,kscan = &kscan0;
		zmk,indicators = &leds;
		zmk,underglow = &rgb_bridge;
	};

	rgb_bridge: rgb_bridge {
		compatible = "zmk,is31fl3733-bridge";
		chain-length = <88>;
	};

	hid_dev_0: hid_dev_0 {
		compatible = "zephyr,hid-device";
		interface-name = "HID0";
		protocol-code = "keyboard";
		in-report-size = <64>;
		in-polling-period-us = <1000>;
	};

	kscan0: kscan_matrix {
		compatible = "zmk,kscan-gpio-matrix";
		diode-direction = "col2row";
		debounce-press-ms = <10>;
		debounce-release-ms = <10>;

		col-gpios = <&gpioe 0 GPIO_ACTIVE_HIGH>,
					<&gpioe 1 GPIO_ACTIVE_HIGH>,
					<&gpioe 2 GPIO_ACTIVE_HIGH>,
					<&gpioe 3 GPIO_ACTIVE_HIGH>,
					<&gpioe 4 GPIO_ACTIVE_HIGH>,
					<&gpioe 5 GPIO_ACTIVE_HIGH>,
					<&gpioe 6 GPIO_ACTIVE_HIGH>,
					<&gpioe 7 GPIO_ACTIVE_HIGH>,
					<&gpioe 8 GPIO_ACTIVE_HIGH>,
					<&gpioe 9 GPIO_ACTIVE_HIGH>,
					<&gpioe 10 GPIO_ACTIVE_HIGH>,
					<&gpioe 11 GPIO_ACTIVE_HIGH>,
					<&gpioe 12 GPIO_ACTIVE_HIGH>,
					<&gpioe 13 GPIO_ACTIVE_HIGH>,
					<&gpioe 14 GPIO_ACTIVE_HIGH>,
					<&gpioe 15 GPIO_ACTIVE_HIGH>,
					<&gpiof 13 GPIO_ACTIVE_HIGH>;

		row-gpios = <&gpiof 2 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
					<&gpiof 3 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
					<&gpiof 4 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
					<&gpiof 5 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
					<&gpiof 10 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
					<&gpiof 11 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>;
	};

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <17>;
		rows = <6>;
		map = <
			RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12)          RC(0,14) RC(0,15) RC(0,16)
			RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14) RC(1,15) RC(1,16)
			RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14) RC(2,15) RC(2,16)
			RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12)          
			RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5) RC(4,6) RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11) RC(4,12)                   RC(4,15)
			RC(5,0) RC(5,1) RC(5,2)                         RC(5,6)                         RC(5,10) RC(5,11) RC(5,12) RC(5,13) RC(5,14) RC(5,15) RC(5,16)
		>;
	};

	leds: leds {
		compatible = "gpio-leds";
		caps_lock_led: caps_lock {
			gpios = <&gpiod 7 GPIO_ACTIVE_HIGH>;
		};
	};

	otghs_ulpi_phy: otghs_ulpis_phy {
		compatible = "usb-ulpi-phy";
		#phy-cells = <0>;
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		code_partition: partition@0 {
			label = "code";
			reg = <0x00000000 0x00100000>;
			read-only;
		};
	};
};

&spi5 {
	pinctrl-0 = <&spi5_sck_pf7 &spi5_miso_pf8 &spi5_mosi_pf9>;
	pinctrl-names = "default";
	status = "okay";
	cs-gpios = <&gpiof 6 GPIO_ACTIVE_LOW>;

	w25q128: w25q128jv@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <40000000>;
		jedec-id = [ef 40 18];
		size = <DT_SIZE_M(128)>;
		has-dpd;
		t-enter-dpd = <3000>;
		t-exit-dpd  = <3000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			storage_partition: partition@0 {
				label = "storage";
				reg = <0x00000000 0x00010000>;
			};

			ext_app_partition: partition@10000 {
				label = "ext-app";
				reg = <0x00010000 0x00FF0000>;
			};
		};
	};
};

&clk_lsi {
	status = "okay";
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(25)>;
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

&pll {
	div-m = <5>;
	mul-n = <110>;
	div-p = <1>;
	div-q = <5>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(550)>;
	d1cpre = <1>;
	hpre = <2>;
	d1ppre = <2>;
	d2ppre1 = <2>;
	d2ppre2 = <2>;
	d3ppre = <2>;
};

&usart2 {
	pinctrl-0 = <&usart2_tx_pa2>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&rtc {
	status = "disabled";
};

&i2c4 {
	pinctrl-0 = <&i2c4_scl_pf14 &i2c4_sda_pf15>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	led_driver1: is31fl3733@50 {
		compatible = "issi,is31fl3733";
		reg = <0x50>;
		sdb-gpios = <&gpiod 11 GPIO_ACTIVE_HIGH>;
		current-limit = <0xff>;
		sync-mode = "none";
	};
};

&i2c2 {
	pinctrl-0 = <&i2c2_scl_pf1 &i2c2_sda_pf0>;
	pinctrl-names = "default";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	led_driver2: is31fl3733@50 {
		compatible = "issi,is31fl3733";
		reg = <0x50>;
		sdb-gpios = <&gpiod 11 GPIO_ACTIVE_HIGH>;
		current-limit = <0xff>;
		sync-mode = "none";
	};
};

zephyr_udc0: &usbotg_hs {
	status = "okay";
	pinctrl-0 = <&usb_otg_hs_ulpi_ck_pa5
			 &usb_otg_hs_ulpi_d0_pa3
			 &usb_otg_hs_ulpi_d1_pb0
			 &usb_otg_hs_ulpi_d2_pb1
			 &usb_otg_hs_ulpi_d3_pb10
			 &usb_otg_hs_ulpi_d4_pb11
			 &usb_otg_hs_ulpi_d5_pb12
			 &usb_otg_hs_ulpi_d6_pb13
			 &usb_otg_hs_ulpi_d7_pb5
			 &usb_otg_hs_ulpi_stp_pc0
			 &usb_otg_hs_ulpi_dir_pc2_c
			 &usb_otg_hs_ulpi_nxt_pc3_c>;
	pinctrl-names = "default";
	maximum-speed = "high-speed";
	clocks = <&rcc STM32_CLOCK_BUS_AHB1 0x6000000>,
		 <&rcc STM32_SRC_HSI48 USB_SEL(3)>;
	phys = <&otghs_ulpi_phy>;
	status = "okay";
};
