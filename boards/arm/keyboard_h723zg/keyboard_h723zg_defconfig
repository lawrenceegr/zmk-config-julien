CONFIG_BOARD_KEYBOARD_H723ZG=y

# Enable GPIO
CONFIG_GPIO=y

# Enable I2C for LED drivers
CONFIG_I2C=y

# IS31FL3733 per-key RGB LED drivers (U3 on i2c4, U4 on i2c2)
# IS31FL3733 driver auto-selects from DT node; no explicit CONFIG_IS31FL3733 needed
CONFIG_LED=y

# LED strip bridge + ZMK RGB underglow
CONFIG_IS31FL3733_BRIDGE=y
CONFIG_ZMK_RGB_UNDERGLOW=y
CONFIG_ZMK_RGB_UNDERGLOW_EXT_POWER=n

# Use pinctrl
# CONFIG_PINCTRL=y

# Enable ZMK outputs
CONFIG_ZMK_USB=y

# Use new USB device stack for High-Speed ULPI PHY support
CONFIG_ZMK_USB_STACK_NEXT=y

# HW stack protection disabled - ARCH_HAS_STACK_PROTECTION not available on this SoC
CONFIG_HW_STACK_PROTECTION=n

# MPU disabled - CPU_HAS_MPU not available on this SoC
CONFIG_ARM_MPU=n

# Enable UART
CONFIG_SERIAL=y

CONFIG_LOG=y
# Console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

CONFIG_PICOLIBC=n
CONFIG_MINIMAL_LIBC=y

