From 9e16ba176be9a46ca4235e71b8ffe0ac2154aa2d Mon Sep 17 00:00:00 2001
From: lawrenceegr <lawrencelangatmi@gmail.com>
Date: Thu, 18 Jun 2026 15:52:06 +0300
Subject: [PATCH] keymap: runtime sensor (encoder) binding get/set +
 persistence

Add zmk_keymap_get_sensor_binding_at_idx / zmk_keymap_set_sensor_binding_at_idx
mirroring the matrix runtime keymap API, with settings persistence
(keymap/s/<layer>/<sensor>), unsaved tracking, save/discard, and load. Lets the
configurator edit encoder sensor-bindings live the same way it edits keys.
---
 app/include/zmk/keymap.h |   5 +
 app/src/keymap.c         | 195 +++++++++++++++++++++++++++++++++++++++
 2 files changed, 200 insertions(+)

diff --git a/app/include/zmk/keymap.h b/app/include/zmk/keymap.h
index 26fd2d16..6fb0a031 100644
--- a/app/include/zmk/keymap.h
+++ b/app/include/zmk/keymap.h
@@ -59,6 +59,11 @@ const struct zmk_behavior_binding *zmk_keymap_get_layer_binding_at_idx(zmk_keyma
 int zmk_keymap_set_layer_binding_at_idx(zmk_keymap_layer_id_t layer, uint16_t binding_idx,
                                         const struct zmk_behavior_binding binding);
 
+const struct zmk_behavior_binding *
+zmk_keymap_get_sensor_binding_at_idx(zmk_keymap_layer_id_t layer, uint8_t sensor_idx);
+int zmk_keymap_set_sensor_binding_at_idx(zmk_keymap_layer_id_t layer, uint8_t sensor_idx,
+                                         const struct zmk_behavior_binding binding);
+
 #if IS_ENABLED(CONFIG_ZMK_KEYMAP_LAYER_REORDERING)
 
 int zmk_keymap_add_layer(void);
diff --git a/app/src/keymap.c b/app/src/keymap.c
index 547d6612..a5543eeb 100644
--- a/app/src/keymap.c
+++ b/app/src/keymap.c
@@ -102,6 +102,18 @@ static struct zmk_behavior_binding
     zmk_sensor_keymap[ZMK_KEYMAP_LAYERS_LEN][ZMK_KEYMAP_SENSORS_LEN] = {
         DT_INST_FOREACH_CHILD_SEP(0, SENSOR_LAYER, (, ))};
 
+#if IS_ENABLED(CONFIG_ZMK_KEYMAP_SETTINGS_STORAGE)
+
+static const struct zmk_behavior_binding
+    zmk_sensor_stock_keymap[ZMK_KEYMAP_LAYERS_LEN][ZMK_KEYMAP_SENSORS_LEN] = {
+        DT_INST_FOREACH_CHILD_SEP(0, SENSOR_LAYER, (, ))};
+
+#define SENSOR_PENDING_ARRAY_SIZE DIV_ROUND_UP(ZMK_KEYMAP_SENSORS_LEN, 8)
+
+static uint8_t zmk_sensor_keymap_pending_changes[ZMK_KEYMAP_LAYERS_LEN][SENSOR_PENDING_ARRAY_SIZE];
+
+#endif // IS_ENABLED(CONFIG_ZMK_KEYMAP_SETTINGS_STORAGE)
+
 #endif /* ZMK_KEYMAP_HAS_SENSORS */
 
 #define ASSERT_LAYER_VAL(_layer, _fail_ret)                                                        \
@@ -328,6 +340,45 @@ int zmk_keymap_set_layer_binding_at_idx(zmk_keymap_layer_id_t layer_id, uint16_t
 }
 
 #endif // IS_ENABLED(CONFIG_ZMK_KEYMAP_SETTINGS_STORAGE)
+
+const struct zmk_behavior_binding *
+zmk_keymap_get_sensor_binding_at_idx(zmk_keymap_layer_id_t layer_id, uint8_t sensor_idx) {
+#if ZMK_KEYMAP_HAS_SENSORS
+    if (sensor_idx >= ZMK_KEYMAP_SENSORS_LEN) {
+        return NULL;
+    }
+
+    ASSERT_LAYER_VAL(layer_id, NULL)
+
+    return &zmk_sensor_keymap[layer_id][sensor_idx];
+#else
+    return NULL;
+#endif
+}
+
+int zmk_keymap_set_sensor_binding_at_idx(zmk_keymap_layer_id_t layer_id, uint8_t sensor_idx,
+                                         struct zmk_behavior_binding binding) {
+#if ZMK_KEYMAP_HAS_SENSORS && IS_ENABLED(CONFIG_ZMK_KEYMAP_SETTINGS_STORAGE)
+    if (sensor_idx >= ZMK_KEYMAP_SENSORS_LEN) {
+        return -EINVAL;
+    }
+
+    ASSERT_LAYER_VAL(layer_id, -EINVAL)
+
+    if (memcmp(&zmk_sensor_keymap[layer_id][sensor_idx], &binding, sizeof(binding)) == 0) {
+        return 0;
+    }
+
+    WRITE_BIT(zmk_sensor_keymap_pending_changes[layer_id][sensor_idx / 8], sensor_idx % 8, 1);
+
+    memcpy(&zmk_sensor_keymap[layer_id][sensor_idx], &binding, sizeof(binding));
+
+    return 0;
+#else
+    return -ENOTSUP;
+#endif
+}
+
 #if IS_ENABLED(CONFIG_ZMK_KEYMAP_LAYER_REORDERING)
 
 #if IS_ENABLED(CONFIG_ZMK_KEYMAP_SETTINGS_STORAGE)
@@ -488,12 +539,23 @@ int zmk_keymap_check_unsaved_changes(void) {
 #endif // IS_ENABLED(CONFIG_ZMK_KEYMAP_LAYER_REORDERING)
     }
 
+#if ZMK_KEYMAP_HAS_SENSORS
+    for (int l = 0; l < ZMK_KEYMAP_LAYERS_LEN; l++) {
+        for (int s = 0; s < ZMK_KEYMAP_SENSORS_LEN; s++) {
+            if (zmk_sensor_keymap_pending_changes[l][s / 8] & BIT(s % 8)) {
+                return 1;
+            }
+        }
+    }
+#endif // ZMK_KEYMAP_HAS_SENSORS
+
     return 0;
 }
 
 #define LAYER_ORDER_SETTINGS_KEY "keymap/layer_order"
 #define LAYER_NAME_SETTINGS_KEY "keymap/l_n/%d"
 #define LAYER_BINDING_SETTINGS_KEY "keymap/l/%d/%d"
+#define SENSOR_BINDING_SETTINGS_KEY "keymap/s/%d/%d"
 
 static int save_bindings(void) {
     for (int l = 0; l < ZMK_KEYMAP_LAYERS_LEN; l++) {
@@ -540,6 +602,49 @@ static int save_bindings(void) {
     return 0;
 }
 
+#if ZMK_KEYMAP_HAS_SENSORS
+static int save_sensor_bindings(void) {
+    for (int l = 0; l < ZMK_KEYMAP_LAYERS_LEN; l++) {
+        uint8_t *pending = zmk_sensor_keymap_pending_changes[l];
+
+        for (int s = 0; s < ZMK_KEYMAP_SENSORS_LEN; s++) {
+            if (pending[s / 8] & BIT(s % 8)) {
+
+                const struct zmk_behavior_binding *binding = &zmk_sensor_keymap[l][s];
+
+                struct zmk_behavior_binding_setting binding_setting = {
+                    .behavior_local_id = zmk_behavior_get_local_id(binding->behavior_dev),
+                    .param1 = binding->param1,
+                    .param2 = binding->param2,
+                };
+
+                size_t len = sizeof(binding_setting);
+                if (binding_setting.param2 == 0) {
+                    len -= 4;
+
+                    if (binding_setting.param1 == 0) {
+                        len -= 4;
+                    }
+                }
+
+                char setting_name[20];
+                sprintf(setting_name, SENSOR_BINDING_SETTINGS_KEY, l, s);
+
+                int ret = settings_save_one(setting_name, &binding_setting, len);
+                if (ret < 0) {
+                    LOG_ERR("Failed to save sensor binding at %d on layer %d (%d)", s, l, ret);
+                    return ret;
+                }
+
+                WRITE_BIT(pending[s / 8], s % 8, 0);
+            }
+        }
+    }
+
+    return 0;
+}
+#endif // ZMK_KEYMAP_HAS_SENSORS
+
 #if IS_ENABLED(CONFIG_ZMK_KEYMAP_LAYER_REORDERING)
 static int save_layer_orders(void) {
     int ret = settings_save_one(LAYER_ORDER_SETTINGS_KEY, keymap_layer_orders,
@@ -576,6 +681,13 @@ int zmk_keymap_save_changes(void) {
         return ret;
     }
 
+#if ZMK_KEYMAP_HAS_SENSORS
+    ret = save_sensor_bindings();
+    if (ret < 0) {
+        return ret;
+    }
+#endif // ZMK_KEYMAP_HAS_SENSORS
+
 #if IS_ENABLED(CONFIG_ZMK_KEYMAP_LAYER_REORDERING)
     ret = save_layer_orders();
     if (ret < 0) {
@@ -615,6 +727,14 @@ int zmk_keymap_discard_changes(void) {
     load_stock_keymap_layer_ordering();
     reload_from_stock_keymap();
 
+#if ZMK_KEYMAP_HAS_SENSORS
+    for (int l = 0; l < ZMK_KEYMAP_LAYERS_LEN; l++) {
+        for (int s = 0; s < ZMK_KEYMAP_SENSORS_LEN; s++) {
+            zmk_sensor_keymap[l][s] = zmk_sensor_stock_keymap[l][s];
+        }
+    }
+#endif // ZMK_KEYMAP_HAS_SENSORS
+
     int ret = settings_load_subtree("keymap");
     if (ret >= 0) {
         changed_layer_names = 0;
@@ -622,6 +742,12 @@ int zmk_keymap_discard_changes(void) {
         for (int l = 0; l < ZMK_KEYMAP_LAYERS_LEN; l++) {
             memset(zmk_keymap_layer_pending_changes[l], 0, PENDING_ARRAY_SIZE);
         }
+
+#if ZMK_KEYMAP_HAS_SENSORS
+        for (int l = 0; l < ZMK_KEYMAP_LAYERS_LEN; l++) {
+            memset(zmk_sensor_keymap_pending_changes[l], 0, SENSOR_PENDING_ARRAY_SIZE);
+        }
+#endif // ZMK_KEYMAP_HAS_SENSORS
     }
 
     return ret;
@@ -921,6 +1047,62 @@ static int keymap_handle_set(const char *name, size_t len, settings_read_cb read
             .param1 = binding_setting.param1,
             .param2 = binding_setting.param2,
         };
+    } else if (settings_name_steq(name, "s", &next) && next) {
+        char *endptr;
+        uint8_t layer = strtoul(next, &endptr, 10);
+        if (*endptr != '/') {
+            LOG_WRN("Invalid layer number: %s with endptr %s", next, endptr);
+            return -EINVAL;
+        }
+
+        uint8_t sensor = strtoul(endptr + 1, &endptr, 10);
+
+        if (*endptr != '\0') {
+            LOG_WRN("Invalid sensor number: %s with endptr %s", next, endptr);
+            return -EINVAL;
+        }
+
+#if ZMK_KEYMAP_HAS_SENSORS
+        if (len > sizeof(struct zmk_behavior_binding_setting)) {
+            LOG_ERR("Too large sensor binding setting size (got %d expected %d)", len,
+                    sizeof(struct zmk_behavior_binding_setting));
+            return -EINVAL;
+        }
+
+        if (layer >= ZMK_KEYMAP_LAYERS_LEN) {
+            LOG_WRN("Layer %d is larger than max of %d", layer, ZMK_KEYMAP_LAYERS_LEN);
+            return -EINVAL;
+        }
+
+        if (sensor >= ZMK_KEYMAP_SENSORS_LEN) {
+            LOG_WRN("Sensor %d is larger than max of %d", sensor, ZMK_KEYMAP_SENSORS_LEN);
+            return -EINVAL;
+        }
+
+        struct zmk_behavior_binding_setting binding_setting = {0};
+        int err = read_cb(cb_arg, &binding_setting, len);
+        if (err <= 0) {
+            LOG_ERR("Failed to handle sensor binding from settings (err %d)", err);
+            return err;
+        }
+
+        const char *sensor_name =
+            zmk_behavior_find_behavior_name_from_local_id(binding_setting.behavior_local_id);
+
+        if (!sensor_name) {
+            LOG_WRN("Loaded device %d from settings but no device found by that local ID",
+                    binding_setting.behavior_local_id);
+        }
+
+        zmk_sensor_keymap[layer][sensor] = (struct zmk_behavior_binding){
+#if IS_ENABLED(CONFIG_ZMK_BEHAVIOR_LOCAL_IDS_IN_BINDINGS)
+            .local_id = binding_setting.behavior_local_id,
+#endif
+            .behavior_dev = sensor_name,
+            .param1 = binding_setting.param1,
+            .param2 = binding_setting.param2,
+        };
+#endif // ZMK_KEYMAP_HAS_SENSORS
     }
 #if IS_ENABLED(CONFIG_ZMK_KEYMAP_LAYER_REORDERING)
     else if (settings_name_steq(name, "layer_order", &next) && !next) {
@@ -959,6 +1141,19 @@ static int keymap_handle_commit(void) {
             }
         }
     }
+
+#if ZMK_KEYMAP_HAS_SENSORS
+    for (int l = 0; l < ZMK_KEYMAP_LAYERS_LEN; l++) {
+        for (int s = 0; s < ZMK_KEYMAP_SENSORS_LEN; s++) {
+            struct zmk_behavior_binding *binding = &zmk_sensor_keymap[l][s];
+
+            if (binding->local_id > 0 && !binding->behavior_dev) {
+                binding->behavior_dev =
+                    zmk_behavior_find_behavior_name_from_local_id(binding->local_id);
+            }
+        }
+    }
+#endif // ZMK_KEYMAP_HAS_SENSORS
 #endif
 
     return 0;
-- 
2.43.0

